#!/bin/sh

set -eu

src_dir="include"
dest_dir="inst/include"
core_src_dir="src_core"
core_dest_dir="src"

mkdir -p "$dest_dir"
rm -f "$dest_dir"/*.hpp

for header in "$src_dir"/*.hpp; do
  [ -e "$header" ] || continue
  cp "$header" "$dest_dir"/
done

mkdir -p "$core_dest_dir"
rm -f "$core_dest_dir"/MonotonicMax.cpp "$core_dest_dir"/MultisetMedian.cpp \
  "$core_dest_dir"/SlidingWelford.cpp "$core_dest_dir"/SlidingWelfordRing.cpp

for source in "$core_src_dir"/*.cpp; do
  [ -e "$source" ] || continue
  cp "$source" "$core_dest_dir"/
done